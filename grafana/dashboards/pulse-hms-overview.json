{
  "title": "Pulse HMS Overview",
  "tags": ["pulse-hms"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "rate(flask_http_request_duration_seconds_count[5m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "title": "HTTP Request Duration (p99)",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(flask_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "title": "Active Requests",
      "type": "graph",
      "span": 4,
      "targets": [
        {
          "expr": "flask_http_request_total - flask_http_request_completed_total",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "HTTP Status Codes",
      "type": "graph",
      "span": 8,
      "targets": [
        {
          "expr": "rate(flask_http_request_duration_seconds_count{status=~\"2..\"}[5m])",
          "legendFormat": "2xx"
        },
        {
          "expr": "rate(flask_http_request_duration_seconds_count{status=~\"4..\"}[5m])",
          "legendFormat": "4xx"
        },
        {
          "expr": "rate(flask_http_request_duration_seconds_count{status=~\"5..\"}[5m])",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "title": "Database Connections",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "flask_exporter_info{service=\"pulse_hms\"}",
          "legendFormat": "up"
        }
      ]
    },
    {
      "title": "Upstream Latency",
      "type": "graph",
      "span": 6,
      "targets": [
        {
          "expr": "rate(flask_http_request_duration_seconds_sum[5m]) / rate(flask_http_request_duration_seconds_count[5m])",
          "legendFormat": "avg {{endpoint}}"
        }
      ]
    }
  ]
}
