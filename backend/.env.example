SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
FLASK_ENV=development

# SQLite (local dev):
DATABASE_URL=sqlite:///backend/pulse_hms.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse_hms

AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://localhost:5173
SOCKET_ASYNC_MODE=threading

# Notification providers (optional — graceful fallback when unset)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# Payment gateway (optional — mock mode when unset)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
