# Backend
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
FLASK_ENV=development

# Database (SQLite for local dev, PostgreSQL for production)
# SQLite:
DATABASE_URL=sqlite:///backend/pulse_hms.db
# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/pulse_hms

# Auto-create tables (set to false when using migrations)
AUTO_CREATE_TABLES=true

# CORS
CORS_ORIGINS=http://localhost:5173

# Socket.IO
SOCKET_ASYNC_MODE=threading

# Frontend (used by Vite)
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
